{
  "defineRoot": "_deuk_define",
  "includePaths": [
    "_deuk_define",
    "_deuk_define/_engine",
    "_deuk_define/generated_define",
    "_deuk_define/game_define",
    "_deuk_define/deuk_table",
    "_deuk_define/msg_user",
    "_deuk_define/msg_server"
  ],
  "jobs": [
    {
      "name": "main",
      "thriftFile": "_deuk_define/_deuk_define.deuk",
      "outputDir": "libDeukDefine/.thrift",
      "csharp": true,
      "cpp": true,
      "json": false,
      "copy": [
        { "from": "libDeukDefine/.thrift/csharp", "to": "libDeukDefine/csharp" },
        { "from": "libDeukDefine/.thrift/cpp", "to": "libDeukDefine/cpp" },
        { "from": "libDeukDefine/.thrift/typescript", "to": "libDeukDefine/javascript" }
      ]
    }
  ]
}

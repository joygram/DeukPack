{
  "defineRoot": "idls",
  "includePaths": [
    "idls",
    "idls/_engine",
    "idls/generated_define",
    "idls/game_define",
    "idls/deuk_table",
    "idls/msg_user",
    "idls/msg_server"
  ],
  "jobs": [
    {
      "name": "main",
      "thriftFile": "idls/idls.deuk",
      "outputDir": "libDeukDefine/.thrift",
      "csharp": true,
      "cpp": true,
      "json": false,
      "copy": [
        { "from": "libDeukDefine/.thrift/csharp", "to": "libDeukDefine/csharp" },
        { "from": "libDeukDefine/.thrift/cpp", "to": "libDeukDefine/cpp" },
        { "from": "libDeukDefine/.thrift/typescript", "to": "libDeukDefine/javascript" }
      ]
    }
  ]
}

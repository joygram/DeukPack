{
  "name": "deukpack",
  "version": "1.2.6",
  "description": "DeukPack — multi-format IDL pipeline (.deuk native, Protobuf, OpenAPI, JSON Schema, CSV, Thrift). Protobuf-aligned wire; fast C#/C++/JS codegen, CLI.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deukpack": "bin/deukpack.js"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "postinstall": "node scripts/npm-postinstall.js",
    "prepublishOnly": "node scripts/sync-version-artifacts.js && npm run build && npm run bundle:vscode",
    "version:sync": "node scripts/sync-version-artifacts.js",
    "postversion": "node scripts/sync-version-artifacts.js",
    "bundle:vscode": "node scripts/bundle-vscode-vsix.js",
    "build": "tsc && node scripts/copy-codegen-templates.js && npm run build:cs && node scripts/dist_csharp.js",
    "build:native": "node-gyp rebuild",
    "build:all": "npm run build && npm run build:cpp && npm run build:cs",
    "build:cpp": "cd native/cpp && mkdir -p build && cd build && cmake .. && make",
    "build:cs": "cd DeukPack.Protocol && dotnet build DeukPack.Protocol.csproj -c Release",
    "test": "jest",
    "test:cpp": "cmake -S native/cpp -B native/cpp/build && cmake --build native/cpp/build && ctest --test-dir native/cpp/build --output-on-failure",
    "benchmark": "node benchmarks/performance.js",
    "dev": "node ./node_modules/typescript/lib/tsc.js --watch",
    "clean": "rimraf dist native/cpp/build native/csharp/bin native/csharp/obj",
    "release-notice:apply": "node scripts/apply-release-notice.js",
    "release:check": "node scripts/release-check.js && npm run build && npm run bundle:vscode && npm test && npm pack --dry-run",
    "verify": "node scripts/verify-build.js",
    "verify:quick": "node scripts/verify-build.js --skip-test --skip-codegen"
  },
  "keywords": [
    "deukpack",
    "deuk",
    "protocol-buffers",
    "protobuf",
    "thrift",
    "typescript",
    "performance",
    "serialization",
    "binary",
    "cross-platform"
  ],
  "author": "gplat-team",
  "license": "Apache-2.0",
  "dependencies": {
    "nan": "^2.26.2",
    "node-addon-api": "^8.6.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.0",
    "@vscode/vsce": "^3.7.1",
    "cmake-js": "^8.0.0",
    "jest": "^30.3.0",
    "node-gyp": "^12.2.0",
    "protobufjs": "^8.0.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joygram/DeukPack.git"
  },
  "bugs": {
    "url": "https://github.com/joygram/DeukPack/issues"
  },
  "homepage": "https://deukpack.app/en/",
  "files": [
    "bin",
    "scripts/build_deukpack.js",
    "scripts/build_unity_runtime_plugins.js",
    "scripts/bootstrap.js",
    "scripts/npm-postinstall.js",
    "scripts/bundled-deuk-idl-vsix.js",
    "scripts/sync_workspace_runtime.js",
    "scripts/deukpack_init.js",
    "scripts/init-ensure-deukpack-npm.js",
    "dist",
    "native/cpp",
    "binding.gyp",
    "LICENSE",
    "NOTICE",
    "release-notice.json",
    "CHANGELOG.md",
    "CHANGELOG.ko.md",
    "CHANGELOG.release.md",
    "CHANGELOG.release.ko.md",
    "bundled",
    "README.md",
    "README.ko.md",
    "RELEASING.md"
  ],
  "deukpack": {
    "csharpRuntime": "dist/csharp"
  }
}

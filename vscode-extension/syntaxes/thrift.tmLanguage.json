{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Deuk IDL (Thrift 호환)",
  "scopeName": "source.thrift",
  "patterns": [
    { "include": "#comments" },
    { "include": "#horizontal-rule" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#namespace-block" },
    { "include": "#thrift-special-keywords" },
    { "include": "#keywords-and-type-names" },
    { "include": "#primitive-types" },
    { "include": "#constant-language" },
    { "include": "#thrift-field-id" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.thrift",
          "begin": "/\\*\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.thrift",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.thrift",
          "match": "//.*$"
        },
        {
          "name": "comment.line.double-slash.thrift",
          "match": "--.*$"
        },
        {
          "name": "comment.line.hash.thrift",
          "match": "#.*$"
        }
      ]
    },
    "horizontal-rule": {
      "name": "comment.line.horizontal-rule.thrift",
      "match": "^-{3,}\\s*$"
    },
    "namespace-block": {
      "patterns": [
        {
          "name": "meta.namespace.thrift",
          "begin": "\\b(namespace)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\{",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "keyword.control.thrift" },
            "2": { "name": "entity.name.namespace.thrift" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.brace.curly.thrift" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#keywords-and-type-names" },
            { "include": "#primitive-types" },
            { "include": "#thrift-field-id" },
            { "include": "#numbers" },
            { "include": "#punctuation" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },
    "thrift-field-id": {
      "comment": "필드 ID 1> 2> — 숫자와 콜론 구분",
      "captures": {
        "1": { "name": "constant.numeric.field-id.thrift" },
        "2": { "name": "punctuation.separator.colon.thrift" }
      },
      "match": "\\b(\\d+)\\s*(:)"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.brace.curly.thrift", "match": "\\{|\\}" },
        { "name": "punctuation.definition.generic.thrift", "match": "<|>" },
        { "name": "punctuation.separator.colon.thrift", "match": ":" },
        { "name": "punctuation.terminator.thrift", "match": ";" },
        { "name": "punctuation.separator.comma.thrift", "match": "," }
      ]
    },
    "thrift-special-keywords": {
      "comment": "테이블·모디파이어(득팩 호환)·필드 한정자 — 스코프 구분",
      "patterns": [
        {
          "name": "storage.type.table.thrift",
          "match": "\\b(table|tablelink|container)\\b"
        },
        {
          "name": "keyword.control.modifier.thrift",
          "match": "\\bmodifier\\b"
        },
        {
          "name": "storage.modifier.thrift",
          "match": "\\b(required|optional)\\b"
        },
        {
          "name": "keyword.other.meta.thrift",
          "match": "\\b(version|key)\\b"
        }
      ]
    },
    "keywords-and-type-names": {
      "patterns": [
        {
          "captures": {
            "1": { "name": "keyword.control.thrift" },
            "2": { "name": "entity.name.type.thrift" }
          },
          "match": "\\b(struct|enum|record|namespace|service|exception|union)\\s+([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
          "name": "keyword.control.thrift",
          "match": "\\b(namespace|include|const|typedef|enum|struct|service|exception|union)\\b"
        }
      ]
    },
    "primitive-types": {
      "name": "storage.type.thrift",
      "match": "\\b(bool|byte|int8|int16|int32|int64|int8|int16|int32|int64|float|double|string|binary|list|set|map)\\b"
    },
    "constant-language": {
      "name": "constant.language.thrift",
      "match": "\\b(true|false)\\b"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.thrift",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.thrift", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.thrift",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.thrift", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.thrift",
      "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
    },
    "identifiers": {
      "comment": "식별자(변수/필드명) — 키워드·타입 매칭 후 남은 단어만",
      "name": "variable.other.thrift",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.assignment.thrift", "match": "=" }
      ]
    }
  }
}
